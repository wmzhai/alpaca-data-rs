def render_module_reference(module: ModuleDoc) -> str:
    methods = module.methods or []
    method_rows = [render_method_row(method, module.module_path) for method in methods]
    request_rows = [render_type_row(type_info, module.module_path) for type_info in module.requests]
    response_rows = [render_type_row(type_info, module.module_path) for type_info in module.responses]
    model_rows = [render_type_row(type_info, module.module_path) for type_info in module.models]
    enum_rows = [render_type_row(type_info, module.module_path) for type_info in module.enums]
    shared_rows = [render_type_row(type_info, module.module_path) for type_info in module.shared]

    sections = [
        "---",
        f'title: "{module.title}"',
        f'description: "{module.summary}"',
        "---",
        "",
        f"# {module.title}",
        "",
        f"- Module path: `{module.module_path}`",
        f"- Client type: `{module.client_type}`" if module.client_type else "- Client type: internal-only module",
        f"- docs.rs module: [{DOCS_RS_BASE}/{module.module_path.replace('::', '/')}/]({DOCS_RS_BASE}/{module.module_path.replace('::', '/')}/)",
        f"- Site rustdoc module: [{DOCS_SITE_URL}api/{module.module_path.replace('::', '/')}/]({DOCS_SITE_URL}api/{module.module_path.replace('::', '/')}/)",
        f"- Scope: {'Internal architecture support only' if module.internal_only else 'Public API surface'}",
        "",
        f"{module.summary}",
        "",
    ]

    if method_rows:
        sections.extend(
            [
                "## Methods",
                "",
                "| Method | Kind | Async | Request | Return | docs.rs | Site rustdoc |",
                "| --- | --- | --- | --- | --- | --- | --- |",
                *method_rows,
                "",
            ]
        )

    for heading, type_list in [
        ("Requests", module.requests),
        ("Responses", module.responses),
        ("Models", module.models),
        ("Enums", module.enums),
        ("Shared Types", module.shared),
    ]:
        if not type_list:
            continue
        sections.extend([f"## {heading}", ""])
        for type_info in type_list:
            sections.extend(render_type_section(type_info, module.module_path))
        sections.append("")

    sections.extend(
        [
            "## Related Repository Artifacts",
            "",
            f"- Examples: {render_path_list(module.examples)}",
            f"- Tests: {render_path_list(module.tests)}",
            f"- Benchmarks: {render_path_list(module.benches)}",
            "",
            "## Coverage Notes",
            "",
            "- The strict endpoint parity ledger for this module lives in [API Coverage](../api-coverage.md).",
            "- Generated reference pages mirror the shipped Rust surface and do not claim unimplemented Alpaca endpoints as available.",
        ]
    )

    return "\n".join(sections).strip() + "\n"


def render_type_row(type_info: TypeInfo, module_path: str) -> str:
    return (
        f"| `{type_info.name}` | {type_info.kind} | {safe_summary(type_info.summary)} | "
        f"[docs.rs]({type_info.docs_rs_url(module_path)}) | [site]({type_info.local_rustdoc_url(module_path)}) |"
    )


def render_type_section(type_info: TypeInfo, module_path: str) -> list[str]:
    lines = [
        f"### `{type_info.name}`",
        "",
        f"- Kind: {type_info.kind}",
        f"- Summary: {safe_summary(type_info.summary)}",
        f"- docs.rs: [{type_info.name}]({type_info.docs_rs_url(module_path)})",
        f"- Site rustdoc: [{type_info.name}]({type_info.local_rustdoc_url(module_path)})",
    ]
    if type_info.aliases_to:
        lines.append(f"- Alias target: `{type_info.aliases_to}`")
    if type_info.wrapper_examples:
        lines.append(f"- Example constructors: {', '.join(f'`{example}`' for example in type_info.wrapper_examples)}")
    if type_info.fields:
        lines.extend(["", "| Field | Official Word | Type | Notes |", "| --- | --- | --- | --- |"])
        for field in type_info.fields:
            lines.append(
                f"| `{field.name}` | `{field.official_name}` | `{field.type_name}` | {safe_summary(field.docs)} |"
            )
    if type_info.variants:
        lines.extend(["", "| Variant | Official Value |", "| --- | --- |"])
        for variant in type_info.variants:
            lines.append(
                f"| `{variant.name}` | `{variant.official_value or variant.name}` |"
            )
    lines.append("")
    return lines


def render_method_row(method: MethodInfo, module_path: str) -> str:
    request = f"`{method.request_type}`" if method.request_type else "-"
    response = f"`{method.return_type}`" if method.return_type else "-"
    return (
        f"| `{method.name}` | {method.kind} | {'yes' if method.is_async else 'no'} | {request} | {response} | "
        f"[docs.rs]({method.docs_rs_url(module_path)}) | [site]({method.local_rustdoc_url(module_path)}) |"
    )


def render_sidebars(schema: dict[str, object]) -> str:
    lines = [
        'import type {SidebarsConfig} from "@docusaurus/plugin-content-docs";',
        "",
        "const sidebars: SidebarsConfig = {",
        "  docsSidebar: [",
    ]
    for section_index, section in enumerate(schema["sections"]):
        lines.extend(
            [
                "    {",
                '      type: "category",',
                f'      label: "{section["label"]}",',
                "      collapsed: false,",
                "      items: [",
            ]
        )
        for item_index, item in enumerate(section["items"]):
            suffix = "," if item_index < len(section["items"]) - 1 else ""
            lines.append(f'        "{item}"{suffix}')
        suffix = "," if section_index < len(schema["sections"]) - 1 else ""
        lines.extend(["      ]", f"    }}{suffix}"])
    lines.extend(["  ]", "};", "", "export default sidebars;"])
    return "\n".join(lines) + "\n"


def update_readme(path: Path, package: PackageInfo, modules: list[ModuleDoc]) -> None:
    readme = path.read_text()
    block = textwrap.dedent(
        f"""\
        {README_BLOCK_START}
        - Documentation site: {DOCS_SITE_URL}
        - Primary API host after publish: {package.documentation}
        - Project Pages route: `{DOCS_SITE_URL}`
        - Local generation: `./tools/docs/generate-doc-site`
        - Local site install: `npm install --prefix website`
        - Local site start: `npm run start --prefix website`
        - Local site build: `npm run build --prefix website`
        - API reference sections:
          - [Documentation Home](docs/index.md)
          - [Getting Started](docs/getting-started.md)
          - [Authentication](docs/authentication.md)
          - [Layers](docs/layers.md)
          - [Project Structure](docs/project-structure.md)
          - [API Reference](docs/reference/index.md)
          - [API Coverage](docs/api-coverage.md)
          - [Examples](docs/examples.md)
          - [Release Checklist](docs/release-checklist.md)
        - Generated module references: {", ".join(f'`docs/reference/{module.doc_slug}.md`' for module in modules)}
        {README_BLOCK_END}
        """
    ).strip()

    if "## Documentation Map" in readme:
        pattern = re.compile(
            rf"(## Documentation Map\n\n)(?:{re.escape(README_BLOCK_START)}.*?{re.escape(README_BLOCK_END)}\n?)?(.*?)(\n## API Audit Script)",
            re.S,
        )
        replacement = rf"\1{block}\n\n\3"
        updated, count = pattern.subn(replacement, readme, count=1)
        if count == 0:
            raise SystemExit("failed to replace README documentation map block")
    else:
        marker = "## API Audit Script"
        if marker not in readme:
            raise SystemExit("README is missing the API audit section marker")
        updated = readme.replace(marker, f"## Documentation Map\n\n{block}\n\n{marker}", 1)

    path.write_text(updated)


def write_json(path: Path, payload: object) -> None:
    path.write_text(json.dumps(payload, indent=2, sort_keys=False) + "\n")


def write_text(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)


def safe_summary(summary: str | None) -> str:
    return summary or "-"


def squash_whitespace(value: str) -> str:
    return re.sub(r"\s+", " ", value).strip()


def clean_markdown(value: str) -> str:
    lines = textwrap.dedent(value).strip().splitlines()
    cleaned = [line[8:] if line.startswith("        ") else line for line in lines]
    return "\n".join(cleaned) + "\n"


def count_kind(methods: list[MethodInfo], kind: str) -> int:
    return sum(1 for method in methods if method.kind == kind)


def render_path_list(paths: list[str]) -> str:
    if not paths:
        return "-"
    return ", ".join(f"`{path}`" for path in paths)


if __name__ == "__main__":
    raise SystemExit(main())
