    ensure_directories()
    package = load_package_info(ROOT)
    type_index = build_type_index(ROOT / "src")
    root_client = parse_root_client(type_index)
    modules = build_module_docs(type_index)
    generated = build_generated_payload(package, root_client, modules)

    write_json(ROOT / "docs/generated/api-index.json", generated["api_index"])
    write_json(ROOT / "docs/generated/project-structure.json", generated["project_structure"])
    write_json(ROOT / "docs/generated/sidebar-schema.json", generated["sidebar_schema"])

    write_text(ROOT / "docs/index.md", render_docs_home(package, modules, root_client))
    write_text(ROOT / "docs/project-structure.md", render_project_structure(modules))
    write_text(ROOT / "docs/reference/index.md", render_reference_index(root_client, modules))
    write_text(ROOT / "docs/reference/client.md", render_client_reference(package, root_client))
