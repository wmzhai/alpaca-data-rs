@dataclass
class PackageInfo:
    name: str
    version: str
    edition: str
    repository: str
    documentation: str
    homepage: str | None
    license: str
    keywords: list[str]
    categories: list[str]


@dataclass
class FieldInfo:
    name: str
    official_name: str
    type_name: str
    docs: str | None = None


@dataclass
class VariantInfo:
    name: str
    official_value: str | None = None


@dataclass
class TypeInfo:
    name: str
    kind: str
    visibility: str
    summary: str | None
    fields: list[FieldInfo] = field(default_factory=list)
    variants: list[VariantInfo] = field(default_factory=list)
    aliases_to: str | None = None
    wrapper_examples: list[str] = field(default_factory=list)
    rustdoc_kind: str = "struct"

    def docs_rs_url(self, module_path: str) -> str:
        rustdoc_name = self.rustdoc_kind
        module_url = module_path.replace("::", "/")
        return f"{DOCS_RS_BASE}/{module_url}/{rustdoc_name}.{self.name}.html"

    def local_rustdoc_url(self, module_path: str) -> str:
        rustdoc_name = self.rustdoc_kind
        module_url = module_path.replace("::", "/")
        return f"{LOCAL_RUSTDOC_BASE}/{module_url}/{rustdoc_name}.{self.name}.html"


@dataclass
class MethodInfo:
    name: str
    kind: str
    owner: str
    is_async: bool
    params: list[tuple[str, str]]
    request_type: str | None
    return_type: str | None
    summary: str | None

    def docs_rs_url(self, module_path: str) -> str:
        module_url = module_path.replace("::", "/")
        return f"{DOCS_RS_BASE}/{module_url}/struct.{self.owner}.html#method.{self.name}"

    def local_rustdoc_url(self, module_path: str) -> str:
        module_url = module_path.replace("::", "/")
        return f"{LOCAL_RUSTDOC_BASE}/{module_url}/struct.{self.owner}.html#method.{self.name}"


